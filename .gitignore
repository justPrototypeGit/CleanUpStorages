# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# The catalog database lives on the user's machine and must never be committed
# (it is data, potentially large, and specific to the local scan history)
*.db
*.db-wal
*.db-shm
catalog.db*

# Scratch / temporary archive rebuild files produced during Case-4 repacks
*.rebuilding.tmp

# OS cruft
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
/.idea/
/.vscode/
*.swp

# Per-drive identity marker written by `volume::resolve` (created wherever a drive is scanned,
# including the repo root during manual smoke tests)
.cleanupstorages_id
UI/

# Design reference input (Google Stitch export) — not part of the build
StitchExport/
# Local agent/session scratch
.user/
.superpowers/

# LinkedIn / marketing post drafts — local only, not part of the project
posts/
